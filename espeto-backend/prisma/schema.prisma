generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" //
  url      = env("DATABASE_URL")
}

model AberturaCaixa {
  id             Int      @id @default(autoincrement())
  data           DateTime @default(now())
  horario        String
  responsavel    String
  valorInicial   Float
  estoqueInicial Json // snapshot do estoque
  createdAt      DateTime @default(now())

  fechamento FechamentoCaixa?
  vendas         VendaAvulsa[]     // Relacionamento inverso
  mesas          Mesa[]            // Relacionamento inverso
}

model VendaAvulsa {
  id       Int              @id @default(autoincrement())
  dataHora DateTime         @default(now())
  itens    ItemVendaAvulsa[]

  aberturaCaixaId  Int?
  aberturaCaixa    AberturaCaixa?   @relation(fields: [aberturaCaixaId], references: [id])
}

model ItemVendaAvulsa {
  id             Int         @id @default(autoincrement())
  vendaAvulsaId  Int
  produtoId      Int
  quantidade     Int
  precoUnitario  Float

  venda   VendaAvulsa @relation(fields: [vendaAvulsaId], references: [id])
  produto Produto     @relation(fields: [produtoId], references: [id])
}

model FechamentoCaixa {
  id                 Int           @id @default(autoincrement())
  aberturaId         Int           @unique
  abertura           AberturaCaixa @relation(fields: [aberturaId], references: [id])
  responsavel        String
  horario            String
  vendasSistema      Float // O que o sistema registrou (Soma de todas as mesas fechadas no período)
  diferencaCaixa     Float         @default(0) // valorFinal - SaldoEsperado
  valorFinal         Float // Dinheiro físico no caixa
  custosOperacionais Json // { carvao: 20, gas: 10, outros: 5 }
  estoqueFinal       Json // Snapshot do estoque no momento do fechamento
  lucroCalculado     Float
  totalPendente      Float @default(0)
  mesasPendente      Json @default("[]")
  createdAt          DateTime      @default(now())
}

model Mesa {
  id         Int           @id @default(autoincrement())
  nome       String
  observacao String?
  status     String        @default("aberta")
  produtos   MesaProduto[]
  total      Float         @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  aberturaCaixaId  Int?           // Para saber em qual turno essa mesa foi aberta
  aberturaCaixa    AberturaCaixa? @relation(fields: [aberturaCaixaId], references: [id])
}

model Produto {
  id             Int               @id @default(autoincrement())
  nome           String
  descricao      String?
  custo          Float
  preco          Float
  categoria      String
  estoque        Int               @default(0)
  estoqueMinimo  Int               @default(0)
  ativo Boolean @default(true)
  
  // Relacionamentos existentes
  mesas          MesaProduto[]
  
  // ADICIONE ESTA LINHA ABAIXO:
  itensVendaAvulsa ItemVendaAvulsa[] 

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model MesaProduto {
  id            Int     @id @default(autoincrement())
  quantidade    Int     @default(1)
  mesa          Mesa    @relation(fields: [mesaId], references: [id])
  mesaId        Int
  produto       Produto @relation(fields: [produtoId], references: [id])
  produtoId     Int
  precoUnitario Float   @default(0)
  subtotal      Float   @default(0)
}
